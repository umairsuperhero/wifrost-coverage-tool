# WiFrost Frontend — environment variables
# For local dev:  copy this file to .env.local  (Next.js loads it automatically)
# For Vercel:     set NEXT_PUBLIC_API_URL in the Vercel dashboard → Project → Settings → Environment Variables
# For Docker:     passed as a build-arg in docker-compose.yml (see docker-compose.yml)

# URL of the WiFrost FastAPI backend.
# Local dev:   http://127.0.0.1:8000
# Production:  https://wifrost-api.onrender.com   ← replace with your actual Render URL
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# WiFrost Frontend — environment variables
# Copy to .env.local for local development; set on Firebase Hosting for production.

# URL of the WiFrost FastAPI backend.
# Local dev:  http://127.0.0.1:8000
# Production: https://wifrost-backend-xxxxx-uc.a.run.app  (your Cloud Run URL)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
